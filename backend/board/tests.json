{
  "tests": [
    {
      "name": "list returns valid structure",
      "method": "POST",
      "path": "/",
      "body": {"action": "list"},
      "expectedStatus": 200,
      "expectedBody": {"total": 0, "sell_count": 0, "buy_count": 0},
      "bodyMatcher": "partial"
    },
    {
      "name": "add listing",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "add",
        "type": "sell",
        "crop": "Пшеница озимая",
        "region": "Самарская",
        "price_per_ton": 13500,
        "volume_tons": 100,
        "contact": "тест",
        "description": "тестовое объявление"
      },
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "validation error on missing crop",
      "method": "POST",
      "path": "/",
      "body": {"action": "add", "type": "sell"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Поле 'crop' обязательно"},
      "bodyMatcher": "partial"
    }
  ]
}