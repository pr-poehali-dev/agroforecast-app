{
  "tests": [
    {
      "name": "GET настройки пользователя по умолчанию",
      "method": "GET",
      "path": "/?user_id=default",
      "expectedStatus": 200,
      "expectedBody": {"user_id": "default"},
      "bodyMatcher": "partial"
    },
    {
      "name": "PUT — сохранить профиль",
      "method": "PUT",
      "path": "/?user_id=default",
      "body": {"profile": {"name": "Тест Тестов", "role": "Фермер", "org": "ООО Тест"}},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "PUT — сохранить регионы",
      "method": "PUT",
      "path": "/?user_id=default",
      "body": {"regions": ["Самарская", "Саратовская"]},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST triggers_list — список триггеров",
      "method": "POST",
      "path": "/",
      "body": {"action": "triggers_list", "user_id": "default"},
      "expectedStatus": 200,
      "expectedBody": {"alert_email": ""},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST triggers_save — добавить ценовой триггер",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "triggers_save",
        "user_id": "default",
        "type": "price",
        "crop": "Пшеница озимая",
        "condition": "above",
        "threshold": 15000
      },
      "expectedStatus": 201,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    }
  ]
}