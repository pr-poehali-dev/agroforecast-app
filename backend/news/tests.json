{
  "tests": [
    {
      "name": "GET — все новости (RSS + fallback)",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"live_count": 0},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET — погода все регионы",
      "method": "GET",
      "path": "/?weather=1",
      "expectedStatus": 200,
      "expectedBody": {"source": "Росгидромет, апрель 2026"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET — погода Волгоград",
      "method": "GET",
      "path": "/?weather=1&region=volgograd",
      "expectedStatus": 200,
      "expectedBody": {"region_id": "volgograd"},
      "bodyMatcher": "partial"
    }
  ]
